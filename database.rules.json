{
  "rules": {
    "noticias": {
      ".read": true,
      ".write": "auth != null && auth.token.firebase.sign_in_provider != 'anonymous'"
    },
    "videos": {
      ".read": true,
      ".write": "auth != null && auth.token.firebase.sign_in_provider != 'anonymous'"
    },
    "site_stats": {
      ".read": true,
      ".write": "auth != null",
      ".validate": "newData.hasChildren(['total_visits', 'daily', 'monthly', 'last_updated'])",
      "total_visits": {
        ".validate": "newData.isNumber() && newData.val() >= 0"
      },
      "unique_total": {
        ".validate": "newData.isNumber() && newData.val() >= 0"
      },
      "daily": {
        "$dateKey": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        }
      },
      "monthly": {
        "$monthKey": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        }
      },
      "hourly": {
        "$dateKey": {
          "$hourKey": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          }
        }
      },
      "unique_daily": {
        "$dateKey": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        }
      },
      "unique_monthly": {
        "$monthKey": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        }
      },
      "unique_hourly": {
        "$dateKey": {
          "$hourKey": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          }
        }
      },
      "pages": {
        "$pageKey": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        }
      },
      "referrers": {
        "$referrerKey": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        }
      },
      "click_targets": {
        "$targetKey": {
          ".validate": "newData.hasChildren(['count']) || !newData.exists()",
          "count": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          }
        }
      },
      "last_updated": {
        ".validate": "newData.isString()"
      }
    },
    "site_unique_views": {
      ".read": "auth != null && auth.token.firebase.sign_in_provider != 'anonymous'",
      ".write": "auth != null"
    },
    "active_users": {
      ".read": "auth != null && auth.token.firebase.sign_in_provider != 'anonymous'",
      ".write": "auth != null"
    },
    "active_users_history": {
      ".read": "auth != null && auth.token.firebase.sign_in_provider != 'anonymous'",
      ".write": "auth != null"
    },
    "click_stats": {
      ".read": "auth != null && auth.token.firebase.sign_in_provider != 'anonymous'",
      ".write": "auth != null",
      "visitors": {
        "$dateKey": {
          "$visitorHash": {
            ".validate": "newData.hasChildren(['total_clicks']) || !newData.exists()",
            "total_clicks": {
              ".validate": "newData.isNumber() && newData.val() >= 0"
            }
          }
        }
      }
    },
    "article_reads": {
      ".read": true,
      "$noticiaId": {
        ".write": "auth != null",
        ".validate": "newData.isNumber() && newData.val() >= 0"
      }
    },
    "likes": {
      ".read": true,
      "$noticiaId": {
        "$userId": {
          ".write": "auth != null",
          ".validate": "(newData.hasChildren(['timestamp']) && newData.child('timestamp').isNumber()) || !newData.exists()",
          "timestamp": {
            ".validate": "newData.isNumber() && newData.val() > 0"
          }
        }
      }
    },
    "comentarios": {
      ".read": true,
      "$noticiaId": {
        "$comentarioId": {
          ".write": "auth != null",
          ".validate": "newData.hasChildren(['nome', 'texto', 'timestamp'])",
          "nome": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
          },
          "texto": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 5000"
          },
          "data": {
            ".validate": "newData.isString()"
          },
          "timestamp": {
            ".validate": "newData.isNumber() && newData.val() > 0"
          },
          "respostas": {
            ".read": true,
            ".write": "auth != null",
            "$respostaId": {
              ".validate": "newData.hasChildren(['nome', 'texto', 'timestamp']) || !newData.exists()",
              "nome": {
                ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
              },
              "texto": {
                ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 5000"
              },
              "data": {
                ".validate": "newData.isString()"
              },
              "timestamp": {
                ".validate": "newData.isNumber() && newData.val() > 0"
              },
              "respostas": {
                ".read": true,
                ".write": "auth != null",
                ".validate": "newData.hasChildren(['nome', 'texto', 'timestamp']) || !newData.exists()"
              }
            }
          }
        }
      }
    }
  }
}
