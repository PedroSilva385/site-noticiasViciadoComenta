{
  "rules": {
    "noticias": {
      ".read": true,
      ".write": "auth != null && auth.token.firebase.sign_in_provider != 'anonymous'"
    },
    "videos": {
      ".read": true,
      ".write": "auth != null && auth.token.firebase.sign_in_provider != 'anonymous'"
    },
    "site_stats": {
      ".read": true,
      ".write": "auth != null",
      ".validate": "newData.hasChildren(['total_visits', 'daily', 'monthly', 'last_updated'])",
      "total_visits": {
        ".validate": "newData.isNumber() && newData.val() >= 0"
      },
      "unique_total": {
        ".validate": "newData.isNumber() && newData.val() >= 0"
      },
      "daily": {
        "$dateKey": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        }
      },
      "monthly": {
        "$monthKey": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        }
      },
      "hourly": {
        "$dateKey": {
          "$hourKey": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          }
        }
      },
      "unique_daily": {
        "$dateKey": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        }
      },
      "unique_monthly": {
        "$monthKey": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        }
      },
      "unique_hourly": {
        "$dateKey": {
          "$hourKey": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          }
        }
      },
      "pages": {
        "$pageKey": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        }
      },
      "referrers": {
        "$referrerKey": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        }
      },
      "click_targets": {
        "$targetKey": {
          ".validate": "newData.hasChildren(['count']) || !newData.exists()",
          "count": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          }
        }
      },
      "last_updated": {
        ".validate": "newData.isString()"
      }
    },
    "site_unique_views": {
      ".read": "auth != null && auth.token.firebase.sign_in_provider != 'anonymous'",
      ".write": "auth != null"
    },
    "active_users": {
      ".read": "auth != null && auth.token.firebase.sign_in_provider != 'anonymous'",
      ".write": "auth != null"
    },
    "active_users_history": {
      ".read": "auth != null && auth.token.firebase.sign_in_provider != 'anonymous'",
      ".write": "auth != null"
    },
    "click_stats": {
      ".read": "auth != null && auth.token.firebase.sign_in_provider != 'anonymous'",
      ".write": "auth != null",
      "visitors": {
        "$dateKey": {
          "$visitorHash": {
            ".validate": "newData.hasChildren(['total_clicks']) || !newData.exists()",
            "total_clicks": {
              ".validate": "newData.isNumber() && newData.val() >= 0"
            }
          }
        }
      }
    },
    "article_reads": {
      ".read": true,
      "$noticiaId": {
        ".write": "auth != null",
        ".validate": "newData.isNumber() && newData.val() >= 0"
      }
    },
    "likes": {
      ".read": true,
      "$noticiaId": {
        "$userId": {
          ".write": "auth != null",
          ".validate": "(newData.hasChildren(['timestamp']) && newData.child('timestamp').isNumber()) || !newData.exists()",
          "timestamp": {
            ".validate": "newData.isNumber() && newData.val() > 0"
          }
        }
      }
    },
    "push_subscriptions": {
      ".read": "auth != null && auth.token.firebase.sign_in_provider != 'anonymous'",
      "$subscriptionId": {
        ".write": "newData.exists() || data.exists()",
        ".validate": "!newData.exists() || ($subscriptionId.matches(/^[a-f0-9]{64}$/) && newData.hasChildren(['subscription', 'topic', 'status', 'createdAt', 'updatedAt', 'lastSeenAt', 'userAgent', 'language', 'origin']) && newData.child('subscription').hasChildren(['endpoint', 'keys']) && newData.child('subscription/endpoint').isString() && newData.child('subscription/endpoint').val().matches(/^https:\\/\\/.+/) && newData.child('subscription/endpoint').val().length <= 1000 && (!newData.child('subscription/expirationTime').exists() || newData.child('subscription/expirationTime').isNumber() || newData.child('subscription/expirationTime').val() == null) && newData.child('subscription/keys').hasChildren(['p256dh', 'auth']) && newData.child('subscription/keys/p256dh').isString() && newData.child('subscription/keys/p256dh').val().length >= 16 && newData.child('subscription/keys/p256dh').val().length <= 512 && newData.child('subscription/keys/auth').isString() && newData.child('subscription/keys/auth').val().length >= 8 && newData.child('subscription/keys/auth').val().length <= 256 && newData.child('topic').isString() && newData.child('topic').val() == 'all' && newData.child('status').isString() && (newData.child('status').val() == 'active' || newData.child('status').val() == 'error' || newData.child('status').val() == 'invalid') && newData.child('createdAt').isNumber() && newData.child('createdAt').val() > 0 && newData.child('updatedAt').isNumber() && newData.child('updatedAt').val() > 0 && newData.child('lastSeenAt').isNumber() && newData.child('lastSeenAt').val() > 0 && newData.child('userAgent').isString() && newData.child('userAgent').val().length <= 300 && newData.child('language').isString() && newData.child('language').val().length <= 32 && newData.child('origin').isString() && newData.child('origin').val().matches(/^https:\\/\\/.+/) && newData.child('origin').val().length <= 120)"
      }
    },
    "push_meta": {
      ".read": false,
      ".write": false
    },
    "comentarios": {
      ".read": true,
      "$noticiaId": {
        "$comentarioId": {
          ".write": "auth != null",
          ".validate": "newData.hasChildren(['nome', 'texto', 'timestamp'])",
          "nome": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
          },
          "texto": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 5000"
          },
          "data": {
            ".validate": "newData.isString()"
          },
          "timestamp": {
            ".validate": "newData.isNumber() && newData.val() > 0"
          },
          "respostas": {
            ".read": true,
            ".write": "auth != null",
            "$respostaId": {
              ".validate": "newData.hasChildren(['nome', 'texto', 'timestamp']) || !newData.exists()",
              "nome": {
                ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
              },
              "texto": {
                ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 5000"
              },
              "data": {
                ".validate": "newData.isString()"
              },
              "timestamp": {
                ".validate": "newData.isNumber() && newData.val() > 0"
              },
              "respostas": {
                ".read": true,
                ".write": "auth != null",
                ".validate": "newData.hasChildren(['nome', 'texto', 'timestamp']) || !newData.exists()"
              }
            }
          }
        }
      }
    }
  }
}
